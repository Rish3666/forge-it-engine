    {
      "parameters": {
        "promptType": "define",
        "text": "=Distro: {{ $json.body.distro || 'arch' }}\nApps: {{ $json.body.apps.join(' ') }}\nGPU: {{ $json.body.gpu }}\nDesktop: {{ $json.body.desktop }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "\"You are a Linux Package Expert. Respond ONLY with a space-separated list of official package names for the requested distro. Do not include 'User ID', 'Apps requested', or any other text.\n\nExample correct output: firefox vlc gimp nvidia-utils\""
        }
      },
      "id": "eb0f9fac-4854-4a98-a203-e01da9e91265",
