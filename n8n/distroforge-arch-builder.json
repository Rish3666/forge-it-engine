    {
      "parameters": {
        "resource": "workflow",
        "owner": "Rish3666",
        "repository": {
          "__rl": true,
          "value": "forge-it-engine",
          "mode": "list",
          "cachedResultName": "forge-it-engine",
          "cachedResultUrl": "https://github.com/Rish3666/forge-it-engine"
        },
        "workflowId": {
          "__rl": true,
          "value": "={{ $node[\"AI Agent\"].json.output.distro }}-builder.yml",
          "mode": "filename"
        },
        "inputs": "={\n  \"packages\": \"{{ $node[\"AI Agent\"].json.output.packages }}\",\n  \"userId\": \"{{ $node[\"Webhook\"].json.body.userId }}\"\n}"
